generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Rayon {
  id           Int     @id @default(autoincrement())
  code         String
  libelle      String
  localisation String
  sousRayon    String  @default("")
  livres       Livre[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([code, sousRayon])

  @@map("rayons")
}

model Livre {
  id               Int       @id @default(autoincrement())
  titre            String
  auteur           String
  isbn             String    @unique
  anneePublication Int
  qteDisponible    Int       @default(0)
  couverture       String?
  couverturePublicId String?
  rayonId          Int
  rayon            Rayon     @relation(fields: [rayonId], references: [id])
  emprunts         Emprunt[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("livres")
}

model Adherent {
  id              Int       @id @default(autoincrement())
  matricule       String    @unique
  prenom          String
  nom             String
  email           String    @unique
  telephone       String
  dateInscription DateTime
  photo           String?
  photoPublicId   String?
  emprunts        Emprunt[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("adherents")
}

model Emprunt {
  id               Int           @id @default(autoincrement())
  adherentId       Int
  livreId          Int
  dateEmprunt      DateTime
  dateRetourPrevue DateTime
  statut           StatutEmprunt @default(EN_COURS)

  adherent         Adherent      @relation(fields: [adherentId], references: [id])
  livre            Livre         @relation(fields: [livreId], references: [id])

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("emprunts")
}

enum StatutEmprunt {
  EN_COURS
  RETOURNE
  EN_RETARD
}
